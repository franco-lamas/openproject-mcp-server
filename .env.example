# OpenProject MCP Server Configuration

# URL of your OpenProject instance (e.g., https://community.openproject.com or http://localhost:8080)
OPENPROJECT_HOST=http://localhost:8080

# Your API Key (Generate it in My Account -> Access Tokens)
# Note: Should be prefixed with "apikey:" (e.g., apikey:1234567890abcdef)
OPENPROJECT_API_KEY=apikey:your_token_here

# SSL verification (set to False for local instances with self-signed certificates)
OPENPROJECT_TLS_VERIFY=True

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
